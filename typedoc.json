{
  "$schema": "https://typedoc.org/schema.json",
  "tsconfig": "tsconfig.docs.json",
  "entryPoints": [
    "src/Aabb.ts",
    "src/app.ts",
    "src/Brand.ts",
    "src/command.ts",
    "src/Definition.ts",
    "src/descriptor.ts",
    "src/entity.ts",
    "src/fx.ts",
    "src/InputAxis.ts",
    "src/label.ts",
    "src/machine.ts",
    "src/query.ts",
    "src/relation.ts",
    "src/Result.ts",
    "src/runtime.ts",
    "src/Scalar.ts",
    "src/schedule.ts",
    "src/schema.ts",
    "src/Size2.ts",
    "src/system.ts",
    "src/Vector2.ts"
  ],
  "entryPointStrategy": "expand",
  "plugin": [
    "typedoc-plugin-markdown",
    "typedoc-vitepress-theme"
  ],
  "theme": "markdown",
  "out": "docs/api",
  "docsRoot": "docs",
  "readme": "none",
  "exclude": [
    "src/internal/**/*.ts",
    "src/examples/**/*.ts",
    "test/**/*.ts",
    "dtslint/**/*.ts"
  ],
  "compilerOptions": {
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "module": "ES2022",
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "rewriteRelativeImportExtensions": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "bevy-ts": [
        "./src/index.ts"
      ],
      "bevy-ts/*": [
        "./src/*.ts"
      ]
    }
  },
  "sidebar": {
    "pretty": true
  },
  "sourceLinkTemplate": "https://github.com/SandroMaglione/bevy-ts/blob/main/{path}#L{line}",
  "gitRemote": "origin",
  "githubPages": false,
  "hideGenerator": true,
  "includeVersion": false
}
