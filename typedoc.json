{
  "$schema": "https://typedoc.org/schema.json",
  "tsconfig": "tsconfig.docs.json",
  "entryPoints": [
    "src/*.ts"
  ],
  "entryPointStrategy": "expand",
  "plugin": [
    "typedoc-plugin-markdown",
    "typedoc-vitepress-theme"
  ],
  "theme": "markdown",
  "out": "docs/api",
  "docsRoot": "docs",
  "readme": "none",
  "exclude": [
    "src/internal/**/*.ts",
    "src/examples/**/*.ts",
    "test/**/*.ts",
    "dtslint/**/*.ts"
  ],
  "compilerOptions": {
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "module": "ES2022",
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "rewriteRelativeImportExtensions": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "bevy-ts": [
        "./src/index.ts"
      ],
      "bevy-ts/*": [
        "./src/*.ts"
      ]
    }
  },
  "sidebar": {
    "pretty": true
  },
  "sourceLinkTemplate": "https://github.com/SandroMaglione/bevy-ts/blob/main/{path}#L{line}",
  "gitRemote": "origin",
  "githubPages": false,
  "hideGenerator": true,
  "includeVersion": false
}
