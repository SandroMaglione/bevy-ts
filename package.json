{
  "name": "bevy-ts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.17.1",
  "homepage": "https://sandromaglione.github.io/bevy-ts",
  "devDependencies": {
    "@effect/platform-node": "4.0.0-beta.43",
    "@types/markdown-it": "^14.1.2",
    "@types/matter-js": "^0.20.2",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260201.1",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/expect": "4.0.18",
    "effect": "4.0.0-beta.43",
    "lightningcss": "1.32.0",
    "markdown-it": "^14.1.1",
    "matter-js": "^0.20.0",
    "pixi.js": "^8.17.1",
    "shiki": "^4.0.2",
    "tstyche": "7.0.0-rc.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "vite": "^8.0.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "scripts": {
    "typecheck": "tsgo -b tsconfig.json",
    "test": "vitest",
    "test-types": "tstyche",
    "check": "pnpm typecheck && pnpm test-types && vitest run",
    "coverage": "vitest --coverage",
    "docs:generate": "tsx scripts/docs.ts",
    "docs:dev": "pnpm docs:generate && vite docs --host",
    "docs:build": "pnpm docs:generate",
    "docs:preview": "vite docs --host",
    "docs:check": "pnpm docs:generate && git diff --exit-code -- docs",
    "example:genetics": "vite --open /examples/genetics/",
    "example:pixi": "vite --open /examples/pixi/",
    "example:platformer": "vite --open /examples/platformer/",
    "example:top-down": "vite --open /examples/top-down/"
  }
}
