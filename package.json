{
  "name": "bevy-ts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.17.1",
  "homepage": "https://sandromaglione.github.io/bevy-ts",
  "devDependencies": {
    "@types/matter-js": "^0.20.2",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260201.1",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/expect": "4.0.18",
    "matter-js": "^0.20.0",
    "pixi.js": "^8.17.1",
    "tstyche": "7.0.0-rc.0",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc-vitepress-theme": "^1.1.2",
    "typescript": "^5.8.2",
    "vite": "^8.0.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitepress": "^1.6.4",
    "vitest": "4.0.18"
  },
  "scripts": {
    "typecheck": "tsgo -b tsconfig.json",
    "test": "vitest",
    "test-types": "tstyche",
    "check": "pnpm typecheck && pnpm test-types && vitest run",
    "coverage": "vitest --coverage",
    "docs:generate": "node scripts/docs.mjs && typedoc && node scripts/docs-api.mjs",
    "docs:dev": "pnpm docs:generate && vitepress dev docs",
    "docs:build": "pnpm docs:generate && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:check": "pnpm docs:generate && git diff --exit-code -- docs",
    "example:pixi": "vite --open /pixi.html",
    "example:platformer": "vite --open /platformer.html",
    "example:top-down": "vite --open /top-down.html"
  }
}
